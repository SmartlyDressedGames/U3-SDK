# EditorConfig is awesome: http://EditorConfig.org

# Top-most EditorConfig file
root = true

# Baseline
[*]
charset = utf-8
indent_style = tab
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = crlf

# Unturned's .dat files
[*.dat]
charset = utf-8
indent_style = tab
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

# Guidelines in c# to help know when to split long lines into multiple.
# In VS requires this extension: https://github.com/pharring/EditorGuidelines
[*.cs]
guidelines = 120

[*.bat]
end_of_line = crlf

[*.sh]
end_of_line = lf

# Unity Style Sheet
[*.uss]
indent_style = space

# Visual Studio autogenerated .editorconfig with some comments added
# Most options are documented here: https://learn.microsoft.com/en-us/visualstudio/ide/code-styles-and-code-cleanup
[*.cs]

#### .NET Coding Conventions ####

# Organize usings
dotnet_separate_import_directive_groups = false
dotnet_sort_system_directives_first = false
file_header_template = unset

# Language keywords vs BCL types preferences
dotnet_style_predefined_type_for_locals_parameters_members = true # private int x rather than private Int32 x. (IDE0049)
dotnet_style_predefined_type_for_member_access = true # int.MaxValue rather than Int32.MaxValue. (IDE0049)

# Parentheses preferences
dotnet_style_parentheses_in_arithmetic_binary_operators = always_for_clarity # a + (b * c)
dotnet_style_parentheses_in_other_binary_operators = always_for_clarity # (a < b) == (c > d)
dotnet_style_parentheses_in_other_operators = never_if_unnecessary # a.b.Length
dotnet_style_parentheses_in_relational_binary_operators = always_for_clarity # a || (b && c)

# Modifier preferences
dotnet_style_require_accessibility_modifiers = always # Prefer accessibility modifiers to be specified even if they are the default.

# Expression-level preferences
dotnet_style_operator_placement_when_wrapping = beginning_of_line
dotnet_style_prefer_auto_properties = false # Don't convert x { get { return _x} } which Unturned has a lot of.
dotnet_style_prefer_compound_assignment = true # x += 1 rather than x = x + 1.
dotnet_style_prefer_conditional_expression_over_assignment = true # Ternary operator.
dotnet_style_prefer_conditional_expression_over_return = true # Ternary operator.
dotnet_style_prefer_is_null_check_over_reference_equality_method = true # is null rather than Object.ReferenceEquals.
dotnet_style_prefer_simplified_boolean_expressions = true # x rather than x ? true : false.
dotnet_style_prefer_simplified_interpolation = true # $"{x}" rather than $"{x.ToString()}".

# Field preferences
dotnet_style_readonly_field = true # Make private fields readonly where possible.

# Suppression preferences
dotnet_remove_unnecessary_suppression_exclusions = none # Keep supressions because Unturned protects Steam callbacks from GC.

#### C# Coding Conventions ####

# var preferences
csharp_style_var_elsewhere = false # bool f = Init() rather than var f = Init().
csharp_style_var_for_built_in_types = false # int x = 5 rather than var x = 5.
csharp_style_var_when_type_is_apparent = false # Item x = new Item() rather than var x = new Item().

# Pattern matching preferences
csharp_style_pattern_matching_over_as_with_null_check = true # (o is string s) rather than o = s as string, s != null.
csharp_style_pattern_matching_over_is_with_cast_check = true # (o is int i) rather than (o is int) i = (int) o.
csharp_style_prefer_not_pattern = true # o is not C c rather than !(o is C c). (IDE0083)
csharp_style_prefer_switch_expression = false # Prefer old-fashioned switch statement. (IDE0066)

# Null-checking preferences
csharp_style_conditional_delegate_call = true # func?.Invoke(args) rather than if (func != null) { func(args); }. (IDE1005)

# Modifier preferences
csharp_prefer_static_local_function = true # Make local functions static. (IDE0062)
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async

# Code-block preferences
csharp_prefer_braces = when_multiline # Prefer curly braces on multiple lines.
csharp_prefer_simple_using_statement = false # using(x) {} (IDE0063)
csharp_style_namespace_declarations = file_scoped # Reduces level of indentation. (IDE0160-0161)

# Expression-level preferences
csharp_prefer_simple_default_expression = true # = default rather than default(T). (IDE0034)
csharp_style_prefer_index_operator = false # [.Length - 1] rather than [^1]. (IDE0056)
csharp_style_prefer_local_over_anonymous_function = true # Require named local functions. (IDE0039)

# 'using' directive preferences
csharp_using_directive_placement = outside_namespace # Above SDG.Unturned namespace. (IDE0065)

#### C# Formatting Rules ####

# New line preferences
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_open_brace = all
csharp_new_line_between_query_expression_clauses = true

# Indentation preferences
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_case_contents_when_block = false
csharp_indent_labels = no_change
csharp_indent_switch_labels = true

# Space preferences
csharp_space_after_cast = true # (int) x rather than (int)x.
csharp_space_after_colon_in_inheritance_clause = true # C : I rather than C :I.
csharp_space_after_comma = true # { 1, 2, 3 } rather than { 1,2 }.
csharp_space_after_dot = false # x.y() rather than x. y().
csharp_space_after_keywords_in_control_flow_statements = true # for () rather than for().
csharp_space_after_semicolon_in_for_statement = true # for (a; b; c) rather than for (a;b;c).
csharp_space_around_binary_operators = before_and_after # a * (b - c) rather than a*(b-c).
csharp_space_around_declaration_statements = false # Remove extra spaces.
csharp_space_before_colon_in_inheritance_clause = true # C : I rather than C: I.
csharp_space_before_comma = false # { 1, 2, 3 } rather than { 1 , 2 }.
csharp_space_before_dot = false # x.y() rather than x .y().
csharp_space_before_open_square_brackets = false # int[] rather than int [].
csharp_space_before_semicolon_in_for_statement = false # for (a; b; c) rather than for (a ;b ;c).
csharp_space_between_empty_square_brackets = false # int[] rather than int[ ].
csharp_space_between_method_call_empty_parameter_list_parentheses = false # f(); rather than f( );.
csharp_space_between_method_call_name_and_opening_parenthesis = false # f() rather than f ().
csharp_space_between_method_call_parameter_list_parentheses = false # f(x) rather than f( x ).
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false # f() {} rather than f () {}.
csharp_space_between_method_declaration_name_and_open_parenthesis = false # f() {} rather than f () {}.
csharp_space_between_method_declaration_parameter_list_parentheses = false # f(int x) rather than f ( int x ).
csharp_space_between_parentheses = false # Remove unnecessary extra spacing around parenthesis.
csharp_space_between_square_brackets = false # arr[0] rather than arr[ 0 ].
