# If using Git LFS, replace "binary" with "filter=lfs diff=lfs merge=lfs -text"

# Mesh files
*.blend binary
*.fbx binary
*.obj binary
*.spm binary
*.mlt binary

# Texture files
*.psd binary
*.xcf binary
*.png binary
*.jpg binary
*.tga binary

# Sound files
*.aup binary
*.aup3 binary
*.au binary
*.mp3 binary
*.ogg binary
*.wav binary
*.aif binary
*.aiff binary

# Unturned files
*.content binary
*.masterbundle binary
*.splatmap binary
*.heightmap binary
*Foliage.blob binary

